{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bojet051.github.io/broiler-production-ontology/curation/candidate-schema.json",
  "title": "Broiler Ontology LLM Curation Candidate",
  "description": "Structured candidate record for proposed ontology additions/changes generated with LLM assistance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "created_at",
    "source_context",
    "entity",
    "change_intent",
    "evidence",
    "qa",
    "review"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "pattern": "^CAND-[0-9]{4}-[0-9]{3}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subdomain", "prompt_version", "generator"],
      "properties": {
        "subdomain": {
          "type": "string",
          "enum": [
            "lifecycle",
            "feed",
            "biosecurity",
            "infrastructure",
            "observation",
            "health",
            "economics",
            "other"
          ]
        },
        "prompt_version": { "type": "string" },
        "generator": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_type",
        "local_name",
        "preferred_label",
        "definition",
        "target_parent"
      ],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": [
            "class",
            "object_property",
            "datatype_property",
            "individual"
          ]
        },
        "local_name": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
        },
        "proposed_iri": { "type": "string", "format": "uri" },
        "preferred_label": { "type": "string", "minLength": 3 },
        "definition": { "type": "string", "minLength": 10 },
        "synonyms": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "target_parent": {
          "type": "string",
          "description": "Superclass or parent relation target (CURIE or IRI)."
        },
        "domain": { "type": "string" },
        "range": { "type": "string" },
        "inverse_of": { "type": "string" },
        "deprecation_replaces": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "axioms": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["axiom_type", "expression_manchester"],
        "properties": {
          "axiom_type": {
            "type": "string",
            "enum": [
              "subclass_of",
              "equivalent_to",
              "disjoint_with",
              "domain",
              "range",
              "inverse_of",
              "restriction",
              "annotation"
            ]
          },
          "expression_manchester": { "type": "string", "minLength": 3 },
          "rationale": { "type": "string" }
        }
      }
    },
    "change_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "backward_compatibility"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["add", "update", "deprecate", "replace"]
        },
        "backward_compatibility": {
          "type": "string",
          "enum": [
            "not_applicable",
            "fully_backward_compatible",
            "requires_deprecation_alias",
            "breaking_change"
          ]
        },
        "breaking_change_notes": { "type": "string" }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_type", "citation", "relevance_statement"],
        "properties": {
          "source_type": {
            "type": "string",
            "enum": ["paper", "standard", "dataset", "codebase", "expert", "other"]
          },
          "citation": { "type": "string", "minLength": 5 },
          "url": { "type": "string", "format": "uri" },
          "quote": { "type": "string" },
          "relevance_statement": { "type": "string", "minLength": 10 }
        }
      }
    },
    "mappings": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_term", "mapping_type", "justification"],
        "properties": {
          "target_term": { "type": "string" },
          "mapping_type": {
            "type": "string",
            "enum": ["exact", "broad", "narrow", "related"]
          },
          "justification": { "type": "string", "minLength": 10 }
        }
      }
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confidence", "risk_level", "semantic_consistency_check"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "semantic_consistency_check": {
          "type": "string",
          "enum": ["pass", "needs_review", "fail"]
        },
        "notes": { "type": "string" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "triaged",
            "accepted",
            "rejected",
            "implemented"
          ]
        },
        "reviewer": { "type": "string" },
        "decision_date": { "type": "string", "format": "date" },
        "decision_notes": { "type": "string" }
      }
    }
  }
}
