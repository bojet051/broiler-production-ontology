:VentilationSystem rdf:type owl:Class ;
                   rdfs:subClassOf :Infrastructure ;
                   rdfs:comment "Mechanical or natural air-exchange system controlling air quality, temperature, and humidity inside the house." ;
                   rdfs:label "Ventilation System" .


###  http://example.org/broiler-ontology#VeterinaryLogistics
:VeterinaryLogistics rdf:type owl:Class ;
                     rdfs:subClassOf :ManagementPractice ;
                     rdfs:comment "Coordination of veterinary services, vaccination programmes, medication, and diagnostic sampling." ;
                     rdfs:label "Veterinary Logistics" .


###  http://example.org/broiler-ontology#WaterQuality
:WaterQuality rdf:type owl:Class ;
              rdfs:subClassOf :ObservableCharacteristic ;
              rdfs:comment "Assessment of the potability and chemical composition of drinking water supplied to broilers." ;
              rdfs:label "Water Quality" .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :EnvironmentalParameter
                :PerformanceIndex
                :WaterQuality
              )
] .


###  http://example.org/broiler-ontology#ObservableCharacteristic
:ObservableCharacteristic rdf:type owl:Class ;
                          rdfs:comment "A characteristic or property kind that observations are about. Major branches include environmental parameters, performance indices, and water-quality characteristics." ;
                          rdfs:label "Observable Characteristic" .


###  http://example.org/broiler-ontology#Observation
:Observation rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty :observesCharacteristic ;
                               owl:someValuesFrom :ObservableCharacteristic
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :observedAt ;
                               owl:someValuesFrom :TimeInstant
                             ] ;
             rdfs:comment "A measurement or assessment event that records a value about a characteristic at a specific time." ;
             rdfs:label "Observation" .


###  http://example.org/broiler-ontology#SensorObservation
:SensorObservation rdf:type owl:Class ;
                   rdfs:subClassOf :Observation ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :observedBySensor ;
                                     owl:someValuesFrom :Sensor
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasNumericValue ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ;
                   rdfs:comment "An observation event produced by a sensor device." ;
                   rdfs:label "Sensor Observation" .


###  http://example.org/broiler-ontology#TimeInstant
:TimeInstant rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty :inXSDDateTime ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ;
             rdfs:comment "A zero-duration temporal point used to timestamp observations." ;
             rdfs:label "Time Instant" .


###  http://example.org/broiler-ontology#TimeInterval
:TimeInterval rdf:type owl:Class ;
              rdfs:comment "A temporal interval used for states or aggregated observations that remain valid for a duration." ;
              rdfs:label "Time Interval" .


###  http://example.org/broiler-ontology#LiveWeightObservation
:LiveWeightObservation rdf:type owl:Class ;
                       owl:equivalentClass [ rdf:type owl:Class ;
                                             owl:intersectionOf ( :SensorObservation
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :observesCharacteristic ;
                                                                    owl:hasValue :LiveWeightCharacteristic
                                                                  ]
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :observedOnBroiler ;
                                                                    owl:someValuesFrom :Broiler
                                                                  ]
                                                                )
                                           ] ;
                       rdfs:comment "Sensor observation whose measured characteristic is live body weight." ;
                       rdfs:label "Live Weight Observation" .


###  http://example.org/broiler-ontology#TemperatureObservation
:TemperatureObservation rdf:type owl:Class ;
                        owl:equivalentClass [ rdf:type owl:Class ;
                                              owl:intersectionOf ( :SensorObservation
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :observesCharacteristic ;
                                                                     owl:hasValue :TemperatureCharacteristic
                                                                   ]
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :observedInInfrastructure ;
                                                                     owl:someValuesFrom :Infrastructure
                                                                   ]
                                                                 )
                                            ] ;
                        rdfs:comment "Sensor observation whose measured characteristic is ambient air temperature." ;
                        rdfs:label "Temperature Observation" .


###  http://example.org/broiler-ontology#pH
:pH rdf:type owl:Class ;
    rdfs:subClassOf :WaterQuality ;
    rdfs:comment "Measure of hydrogen-ion activity indicating acidity or alkalinity of drinking water." ;
    rdfs:label "pH" .


###  http://example.org/broiler-ontology#BiosecuredInfrastructure
:BiosecuredInfrastructure rdf:type owl:Class ;
                          owl:equivalentClass [ rdf:type owl:Class ;
                                                owl:intersectionOf ( :Infrastructure
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :hasBiosecurityProtocol ;
                                                                       owl:someValuesFrom :Biosecurity
                                                                     ]
                                                                   )
                                              ] ;
                          rdfs:comment "Infrastructure that has at least one biosecurity protocol applied." ;
                          rdfs:label "Biosecured Infrastructure" .


###  http://example.org/broiler-ontology#BroodingStarterBroiler
:BroodingStarterBroiler rdf:type owl:Class ;
                        owl:equivalentClass [ rdf:type owl:Class ;
                                              owl:intersectionOf ( :Broiler
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasCurrentPhase ;
                                                                     owl:hasValue :BroodingPhase
                                                                   ]
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasFeedBatch ;
                                                                     owl:someValuesFrom :StarterFeed
                                                                   ]
                                                                 )
                                            ] ;
                        rdfs:comment "Broiler currently in brooding phase and receiving starter feed." ;
                        rdfs:label "Brooding Starter Broiler" .


###  http://example.org/broiler-ontology#MaleBroiler
:MaleBroiler rdf:type owl:Class ;
             owl:disjointWith :FemaleBroiler ;
             owl:equivalentClass [ rdf:type owl:Class ;
                                   owl:intersectionOf ( :Broiler
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :hasGender ;
                                                          owl:hasValue :Male
                                                        ]
                                                      )
                                 ] ;
             rdfs:comment "Broiler whose gender value is Male." ;
             rdfs:label "Male Broiler" .


###  http://example.org/broiler-ontology#FemaleBroiler
:FemaleBroiler rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:intersectionOf ( :Broiler
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :hasGender ;
                                                            owl:hasValue :Female
                                                          ]
                                                        )
                                   ] ;
               rdfs:comment "Broiler whose gender value is Female." ;
               rdfs:label "Female Broiler" .


