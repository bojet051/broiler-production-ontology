:Cobb500MaleBroiler rdf:type owl:Class ;
                    owl:equivalentClass [ rdf:type owl:Class ;
                                          owl:intersectionOf ( :Cobb500Broiler
                                                               :MaleBroiler
                                                             )
                                        ] ;
