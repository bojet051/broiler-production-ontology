###  http://example.org/broiler-ontology#SensorMonitoredInfrastructure
:SensorMonitoredInfrastructure rdf:type owl:Class ;
                               owl:equivalentClass [ rdf:type owl:Class ;
                                                     owl:intersectionOf ( :Infrastructure
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :monitoredBy ;
                                                                            owl:someValuesFrom :Sensor
                                                                          ]
                                                                        )
                                                   ] ;
                               rdfs:comment "Infrastructure that is monitored by at least one sensor." ;
                               rdfs:label "Sensor-Monitored Infrastructure" .


#################################################################
#    Individuals
#################################################################

###  http://example.org/broiler-ontology#BroodingPhase
:BroodingPhase rdf:type owl:NamedIndividual ,
                        :ProductionLifecycle ;
               owl:differentFrom :GrowingPhase ,
                                 :PreProcessing ;
               rdfs:comment "Controlled-vocabulary phase value for the initial brooding period, typically days 0 to 14." ;
               rdfs:label "Brooding Phase" .


###  http://example.org/broiler-ontology#Female
:Female rdf:type owl:NamedIndividual ,
                 :Gender ;
        owl:differentFrom :Male ;
        rdfs:comment "A female broiler chicken." ;
        rdfs:label "Female" .


###  http://example.org/broiler-ontology#GrowingPhase
:GrowingPhase rdf:type owl:NamedIndividual ,
                       :ProductionLifecycle ;
              owl:differentFrom :PreProcessing ;
              rdfs:comment "Controlled-vocabulary phase value for the intermediate growing period, typically days 15 to 28." ;
              rdfs:label "Growing Phase" .


###  http://example.org/broiler-ontology#Male
:Male rdf:type owl:NamedIndividual ,
               :Gender ;
      rdfs:comment "A male broiler chicken." ;
      rdfs:label "Male" .


###  http://example.org/broiler-ontology#LiveWeightCharacteristic
:LiveWeightCharacteristic rdf:type owl:NamedIndividual ,
                                   :ObservableCharacteristic ;
                          rdfs:comment "Controlled-vocabulary individual representing live body weight as an observable characteristic." ;
                          rdfs:label "Live Weight Characteristic" .

###  http://example.org/broiler-ontology#PreProcessing
:PreProcessing rdf:type owl:NamedIndividual ,
                        :ProductionLifecycle ;
               rdfs:comment "Controlled-vocabulary phase value for the final pre-processing period before slaughter." ;
               rdfs:label "Pre-Processing Phase" .


###  http://example.org/broiler-ontology#TemperatureCharacteristic
:TemperatureCharacteristic rdf:type owl:NamedIndividual ,
                                    :ObservableCharacteristic ;
                           rdfs:comment "Controlled-vocabulary individual representing ambient air temperature." ;
                           rdfs:label "Temperature Characteristic" .


