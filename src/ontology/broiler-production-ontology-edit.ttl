:Ross308Broiler rdf:type owl:Class ;
                owl:equivalentClass [ rdf:type owl:Class ;
                                      owl:intersectionOf ( :Broiler
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :hasBreedLine ;
                                                             owl:someValuesFrom :Ross308
                                                           ]
                                                         )
                                    ] ;
                rdfs:comment "Broiler classified as Ross 308 by breed relation." ;
